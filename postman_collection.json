              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Application is healthy', () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status).to.equal('UP');",
