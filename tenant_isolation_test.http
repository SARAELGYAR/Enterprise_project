    });
%}

### === Security Validation Tests ===

### Try to create task with wrong tenant project (should fail)
POST {{baseUrl}}/tasks
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhZG1pbkB0ZW5hbnQxLmNvbSIsInRlbmFudElkIjoiMTkwMzY0Y2YtZTdiNS00ODdiLTk0MWMtODgyZTY3NjY4MTdlIiwicm9sZXMiOiJURU5BTlRfQURNSU4iLCJpYXQiOjE3NzgwODg0NDQsImV4cCI6MTc3ODE3NDg0NH0.mMoOSW30FsG6T5Y9JJUscbQfnkAIGZhuafG0NBvyixkQejKdWhNdSHorSnvIKKbLmmtR_yxDEw2cZ5HrMTfkYQ
Content-Type: application/json

{
  "title": "Invalid Task",
  "status": "TODO",
  "projectId": "3a511d3d-3147-48eb-bcb4-1914d621f1db"
}

> {%
    client.test("Cannot create task for different tenant project", function() {
        client.assert(response.status === 400, "Should reject task for different tenant project");
    });
%}

### Try to access endpoint without token (should fail)
GET {{baseUrl}}/projects

> {%
    client.test("Unauthorized access blocked", function() {
        client.assert(response.status === 401 || response.status === 403, "Should require authentication");
    });
%}

### === Cleanup Tests ===

### Delete Tenant 1 Task
DELETE {{baseUrl}}/tasks/ef56b4fb-af87-42bd-809f-26db4f3b7340
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhZG1pbkB0ZW5hbnQxLmNvbSIsInRlbmFudElkIjoiMTkwMzY0Y2YtZTdiNS00ODdiLTk0MWMtODgyZTY3NjY4MTdlIiwicm9sZXMiOiJURU5BTlRfQURNSU4iLCJpYXQiOjE3NzgwODg0NDQsImV4cCI6MTc3ODE3NDg0NH0.mMoOSW30FsG6T5Y9JJUscbQfnkAIGZhuafG0NBvyixkQejKdWhNdSHorSnvIKKbLmmtR_yxDEw2cZ5HrMTfkYQ

> {%
