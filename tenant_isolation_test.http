### Try to access Tenant 2 project as Tenant 1 (should fail)
GET {{baseUrl}}/projects/3a511d3d-3147-48eb-bcb4-1914d621f1db
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhZG1pbkB0ZW5hbnQxLmNvbSIsInRlbmFudElkIjoiMTkwMzY0Y2YtZTdiNS00ODdiLTk0MWMtODgyZTY3NjY4MTdlIiwicm9sZXMiOiJURU5BTlRfQURNSU4iLCJpYXQiOjE3NzgwODg0NDQsImV4cCI6MTc3ODE3NDg0NH0.mMoOSW30FsG6T5Y9JJUscbQfnkAIGZhuafG0NBvyixkQejKdWhNdSHorSnvIKKbLmmtR_yxDEw2cZ5HrMTfkYQ

> {%
    client.test("Cross-tenant project access blocked", function() {
        client.assert(response.status === 404 || response.status === 403, "Cross-tenant access should be blocked");
    });
%}

### === Task Isolation Tests ===

### Create Task for Tenant 1 Project
POST http://localhost:8080/tasks
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhZG1pbkB0ZW5hbnQxLmNvbSIsInRlbmFudElkIjoiMTkwMzY0Y2YtZTdiNS00ODdiLTk0MWMtODgyZTY3NjY4MTdlIiwicm9sZXMiOiJURU5BTlRfQURNSU4iLCJpYXQiOjE3NzgwODExNzgsImV4cCI6MTc3ODE2NzU3OH0.mJDwkZ2mZMfPy1mJ06GKhGle4igmmrUsTHc1-pQZzedoVo2iYT6eRhOtJ1ZQHbzY4iOjZO086AekROI7pPvPLA
Content-Type: application/json

{
  "title": "Tenant 1 Task",
  "status": "TODO",
  "projectId": "ca8ffc47-1239-4fa9-8c73-90a52cd62fe9"
}

> {%
    client.test("Tenant 1 task created", function() {
        client.assert(response.status === 200, "Task creation failed");
        client.global.set("tenant1TaskId", response.body.id);
    });
%}

### Create Task for Tenant 2 Project
POST {{baseUrl}}/tasks
Authorization: Bearer {{tenant2Token}}
Content-Type: application/json

{
  "title": "Tenant 2 Task",
  "status": "TODO",
  "projectId": "{{tenant2ProjectId}}"
}

> {%
    client.test("Tenant 2 task created", function() {
        client.assert(response.status === 200, "Task creation failed");
        client.global.set("tenant2TaskId", response.body.id);
    });
%}

